# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and read automatically by Vite (dev) — never commit real keys.

# ── Supabase (cloud sync + login) ──
# From your Supabase project: Settings → API. Leave BOTH blank to stay in
# local/browser-only mode with no login. Fill both to turn on cloud sync.
# The anon key is safe to expose in the browser (Row Level Security protects data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Free US Census API key — unlocks income & demographics in area lookups.
# Get one instantly at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# (Later) Crime/safety provider key — RentCast or ATTOM. Leave blank to keep safety stubbed.
# CRIME_API_KEY=
